# =============================================================================
# LifeHub - Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Used by docker-compose and can be sourced for local development.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=your_secure_db_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 96
JWT_SECRET=replace-with-secure-random-string-at-least-64-characters-long

# ── Spring Profile ────────────────────────────────────────────────────────────
# Options: dev | prod
SPRING_PROFILES_ACTIVE=dev
