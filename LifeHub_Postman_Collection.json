	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data && jsonData.data.token) {",
									"        var token = jsonData.data.token;",
									"        // Try to save to environment first, then collection variable",
									"        if (pm.environment) {",
									"            pm.environment.set(\"auth_token\", token);",
									"        }",
									"        // Also save to collection variable as fallback",
									"        pm.collectionVariables.set(\"auth_token\", token);",
									"        console.log(\"Token saved to auth_token variable:\", token.substring(0, 20) + \"...\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Demo User\",\n    \"email\": \"demo@lifehub.com\",\n    \"password\": \"demo123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Register a new user account"
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data && jsonData.data.token) {",
									"        var token = jsonData.data.token;",
									"        // Try to save to environment first, then collection variable",
									"        if (pm.environment) {",
									"            pm.environment.set(\"auth_token\", token);",
									"        }",
									"        // Also save to collection variable as fallback",
									"        pm.collectionVariables.set(\"auth_token\", token);",
									"        console.log(\"Token saved to auth_token variable:\", token.substring(0, 20) + \"...\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"demo@lifehub.com\",\n    \"password\": \"demo123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login and get JWT token"
					},
					"response": []
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/me",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "me"]
						},
						"description": "Get current authenticated user profile"
					},
					"response": []
				}
			],
			"description": "Authentication endpoints"
